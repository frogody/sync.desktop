# Together.ai API key for semantic analysis
# Required for LLM-powered context analysis (commitments, action items, work context)
# Without this key, the app silently falls back to quick-analysis-only mode
TOGETHER_API_KEY=your_together_api_key_here

# Optional: Override Supabase settings (defaults are in src/shared/constants.ts)
# SUPABASE_URL=https://sfxpmzicgpaxfntqleig.supabase.co
# SUPABASE_ANON_KEY=your_anon_key_here

# Apple code signing identity (required for signed macOS builds)
# Format: "Developer Name (TEAM_ID)"
# APPLE_SIGNING_IDENTITY=Your Name (TEAMID)

# Apple notarization (required for signed macOS builds)
# APPLE_ID=your_apple_id@example.com
# APPLE_APP_SPECIFIC_PASSWORD=your_app_specific_password
# APPLE_TEAM_ID=your_team_id

# Set to "true" to skip notarization during local development builds
# SKIP_NOTARIZE=true

# Vite dev server URL (set automatically by concurrently; override if needed)
# VITE_DEV_SERVER_URL=http://localhost:5173
